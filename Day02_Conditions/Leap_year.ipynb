   "source": [
    "year = int(input(\"enter the year\\n\"))\n",
    "\n",
    "if year == 0:\n",
    "    print(\"Year 0 is not valid\")\n",
    "elif (year % 400 == 0) or (year % 4 == 0 and year % 100 != 0):\n",
    "    print(year, \"is a Leap Year\")\n",
    "else:\n",
    "    print(year, \"is not a Leap Year\")"
   ]
  }
