    "import matplotlib.pyplot as plt\n",
    "\n",
    "x = [1,2,3,4,5,6]\n",
    "y = [2,4,6,4,7,8]\n",
    "\n",
    "plt.step(x,y,color=\"r\",marker=\"o\",label=\"Matplot\")\n",
    "\n",
    "\n",
    "plt.title(\"Matplot\")\n",
    "plt.xlabel(\"x-axis\")\n",
    "plt.ylabel(\"y-axis\")\n",
    "plt.grid()\n",
    "\n",
    "plt.legend()\n",
    "plt.show()"
   ]
