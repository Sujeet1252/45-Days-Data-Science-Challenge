   "source": [
    "def factorial(n):\n",
    "    fact = 1\n",
    "\n",
    "    for i in range(1, n+1):\n",
    "        fact *= i\n",
    "\n",
    "    return fact\n",
    "\n",
    "num = int(input(\"Enter a number : \"))\n",
    "\n",
    "print(\"Factorial of \" , num , \"is :\" ,  factorial(num)) "
   ]
  }
 ],
