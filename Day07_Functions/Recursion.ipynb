   "source": [
    "def print_numbers(n):\n",
    "\n",
    "    if n>5:  #base case\n",
    "        return\n",
    "    print(n)\n",
    "\n",
    "    print_numbers(n+1) #recursive call\n",
    "\n",
    "print_numbers(1)"
   ]
