   "source": [
    "# Factorial \n",
    "\n",
    "def factorial(n):\n",
    "\n",
    "    if n == 1 : #base case\n",
    "        return 1\n",
    "\n",
    "    return n * factorial(n-1)\n",
    "\n",
    "print(factorial(5))"
   ]
  },
