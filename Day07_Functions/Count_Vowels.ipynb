   "source": [
    "def count_vowels(words):\n",
    "    count = 0\n",
    "\n",
    "    for char in words:\n",
    "        if char.lower() in \"aeiou\":\n",
    "            count += 1\n",
    "\n",
    "    return count\n",
    "\n",
    "print(\"Total no. of vowels are : \", count_vowels(\"Data Science Learning\"))"
   ]
  }
