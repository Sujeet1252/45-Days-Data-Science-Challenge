   "outputs": [],
   "source": [
    "sentence = input(\"Enter a sentence: \")\n",
    "\n",
    "words = sentence.split()\n",
    "\n",
    "unique_words = []\n",
    "\n",
    "for word in words:\n",
    "    \n",
    "    if word not in unique_words:\n",
    "        \n",
    "        unique_words.append(word)\n",
    "\n",
    "result = \" \".join(unique_words)\n",
    "\n",
    "print(\"Sentence without duplicates:\")\n",
    "print(result)"
   ]
  }
 ],
