   "source": [
    "string = input(\"Enter the string :\")\n",
    "\n",
    "reverse_string = string[::-1]\n",
    "\n",
    "print(\"Reverse of String is :\", reverse_string)\n",
    "\n",
    "\n",
    "if reverse_string == string:\n",
    "    print(\"Plaindrome String\")\n",
    "else:\n",
    "    print(\"Not a palindrome String\")"
   ]
