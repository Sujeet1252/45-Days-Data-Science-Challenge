   ],
   "source": [
    "string = input(\"Enter a string: \")\n",
    "\n",
    "frequency = {}\n",
    "\n",
    "for char in string:\n",
    "    if char in frequency:\n",
    "        frequency[char] += 1\n",
    "    else:\n",
    "        frequency[char] = 1\n",
    "\n",
    "print(\"\\nCharacter Frequencies:\")\n",
    "\n",
    "for char, count in frequency.items():\n",
    "    print(char, \"=\", count)\n"
   ]
  },
