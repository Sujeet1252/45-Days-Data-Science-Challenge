   "source": [
    "string = input(\"Enter a sentence: \")\n",
    "\n",
    "count = 1\n",
    "\n",
    "for char in string:\n",
    "    if char == \" \":\n",
    "        count += 1\n",
    "\n",
    "print(\"Number of words :\", count)"
   ]
