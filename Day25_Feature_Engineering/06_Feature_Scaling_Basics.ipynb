        "from sklearn.preprocessing import MinMaxScaler\n",
        "df=pd.DataFrame({'Age':[20,30,40],'Salary':[25000,50000,75000]})\n",
        "print(pd.DataFrame(MinMaxScaler().fit_transform(df),columns=df.columns))\n"
      ]
