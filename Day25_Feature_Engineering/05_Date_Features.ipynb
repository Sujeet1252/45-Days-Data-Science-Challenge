      "source": [
        "import pandas as pd\n",
        "df=pd.DataFrame({'Date':['2022-01-10','2023-05-20']})\n",
        "df['Date']=pd.to_datetime(df['Date'])\n",
        "df['Year']=df['Date'].dt.year\n",
        "print(df)\n"
      ]
    }
