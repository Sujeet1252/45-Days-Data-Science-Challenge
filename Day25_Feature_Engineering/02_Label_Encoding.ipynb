      "metadata": {},
      "outputs": [],
      "source": [
        "import pandas as pd\n",
        "from sklearn.preprocessing import LabelEncoder\n",
        "df=pd.DataFrame({'Gender':['Male','Female','Male']})\n",
        "le=LabelEncoder()\n",
        "df['Gender_Encoded']=le.fit_transform(df['Gender'])\n",
        "print(df)\n"
      ]
    }
  ],
