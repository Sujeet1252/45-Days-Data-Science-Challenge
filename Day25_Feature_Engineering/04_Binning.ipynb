      "source": [
        "import pandas as pd\n",
        "df=pd.DataFrame({'Age':[18,22,35,45]})\n",
        "df['Age_Group']=pd.cut(df['Age'],bins=[0,25,40,100],labels=['Young','Adult','Senior'])\n",
        "print(df)\n"
      ]
    }
