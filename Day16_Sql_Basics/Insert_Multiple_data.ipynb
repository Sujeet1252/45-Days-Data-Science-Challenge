   "source": [
    "import sqlite3\n",
    "\n",
    "conn = sqlite3.connect(\"student.db\")\n",
    "\n",
    "cursor = conn.cursor()\n",
    "\n",
    "student= [\n",
    "    (2,\"Rahul\",85),\n",
    "    (3,\"Mohit\",80),\n",
    "    (4,\"Ram\",90),\n",
    "    (5,\"Sam\",75)\n",
    "]\n",
    "\n",
    "cursor.executemany(\n",
    "\"Insert  Or Ignore Into Student Values (?,?,?)\", student\n",
    ")\n",
    "conn.commit()\n",
    "\n",
    "print(\"Student Added\")"
   ]
  }
 ],
