   "source": [
    "import sqlite3 \n",
    "\n",
    "conn = sqlite3.connect(\"student.db\")\n",
    "\n",
    "cursor = conn.cursor()\n",
    "\n",
    "cursor.execute(\"\"\"\n",
    "CREATE TABLE IF NOT EXISTS Student(\n",
    "    ID INTEGER PRIMARY KEY,\n",
    "    Name TEXT,\n",
    "    Marks INTEGER\n",
    ")\n",
    "\"\"\")\n",
    "\n",
    "print(\"Table created successfully\")"
   ]
  }
 ],
