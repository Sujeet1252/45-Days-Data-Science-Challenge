   "source": [
    "num = int(input(\"Enter a number\"))\n",
    "\n",
    "sum =0\n",
    "while num>0:\n",
    "    digit = num%10\n",
    "    sum += digit\n",
    "    num = num//10\n",
    "\n",
    "print(\"sum of digits: \",sum)\n"
   ]
