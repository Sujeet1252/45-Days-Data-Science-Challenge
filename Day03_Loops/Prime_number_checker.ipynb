   "source": [
    "num = int(input(\"Enter a number: \"))\n",
    "\n",
    "if num <= 1:\n",
    "    print(\"Prime no. should be greater than 1\")\n",
    "else:\n",
    "    for i in range(2,num):\n",
    "        if  num %i ==0:\n",
    "            print(\"Not a prime number\")\n",
    "            break\n",
    "    else:\n",
    "        print(\"Prime number\")"
   ]
  }
