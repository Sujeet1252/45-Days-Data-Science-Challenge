   "source": [
    "num = int(input(\"Enter a number: \"))\n",
    "\n",
    "original=num\n",
    "reverse = 0\n",
    "\n",
    "while num > 0:\n",
    "    digit = num % 10\n",
    "    reverse = reverse * 10 + digit\n",
    "    num = num // 10\n",
    "\n",
    "print(\"Reversed Number is: \", reverse)\n",
    "\n",
    "if reverse==original:\n",
    "    print(\"palindrome\")\n",
    "else:\n",
    "    print(\"Not Palindrome\")"
   ]
  }
 ],
